{
  "title": "IMN decrypted callback",
  "type": "object",
  "description": "This is received by the merchant after decrypting the crypted Instant Merchant notification callback.\n\nThis answer contains all needed data for the merchant to update his databases and process the operations after a successful payment (send invoices, updates orders, etc.)\n\nDepending on the type of payment needed (one off, membership, odrp, etc.) the answer contains the relevant datas.",
  "examples": [],
  "properties": {
    "amount": {
      "type": "string",
      "description": "Amount in cents"
    },
    "currency": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "success",
        "fail"
      ],
      "example": "success"
    },
    "checksum": {
      "type": "string",
      "description": "HASH of all parameters in the order of apearence"
    },
    "id_order": {
      "type": "string"
    },
    "transaction_id": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "description": "Payment method"
    },
    "reference": {
      "type": "string",
      "description": "reference number for differed payment mode"
    },
    "payment_method": {
      "type": "string",
      "description": "Payment method."
    },
    "additional_param": {
      "type": "string",
      "description": "Additionnal parameter that has been sent when loading the iframe"
    },
    "reason_fail": {
      "type": "string",
      "description": "only for fail payment"
    },
    "token": {
      "$ref": "./Token.json"
    },
    "card_details": {
      "type": "object",
      "description": "Only if payment_method is equal to card",
      "properties": {
        "masked_card_number": {
          "type": "string",
          "example": "123456xxxxxx1234",
          "description": "Masked Card number"
        },
        "expiry_date": {
          "type": "string",
          "example": "06/22",
          "default": "mm/yy"
        },
        "card_brand": {
          "type": "string",
          "x-stoplight": {
            "id": "whj5gutzjrffc"
          }
        }
      }
    },
    "transaction_details": {
      "type": "object",
      "x-stoplight": {
        "id": "iaul9rhu6djhh"
      },
      "description": "Only available if it is a card POS payment",
      "properties": {
        "APPROVAL_CODE": {
          "type": "string",
