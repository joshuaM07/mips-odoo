    "/load_payment_zone": {
      "post": {
        "summary": "Load Payment Zone",
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../models/iFrame-result.json"
                }
              },
              "text/html": {
                "schema": {
                  "type": "object",
                  "properties": {}
                }
              },
              "application/xml": {
                "schema": {
                  "type": "object",
                  "properties": {}
                }
              },
              "multipart/form-data": {
                "schema": {
                  "type": "object",
                  "properties": {}
                }
              },
              "application/EDIFACT": {
                "schema": {
                  "type": "object",
                  "properties": {}
                }
              },
              "text/plain": {
                "schema": {
                  "type": "object",
                  "properties": {}
                }
              }
            },
            "headers": {}
          }
        },
        "operationId": "load-payment-zone",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "authentify",
                  "order",
                  "request_mode",
                  "touchpoint"
                ],
                "properties": {
                  "authentify": {
                    "$ref": "../models/Authentify.json"
                  },
                  "order": {
                    "$ref": "../models/Order.json"
                  },
                  "iframe_behavior": {
                    "$ref": "../models/iFrame-behavior.json"
                  },
                  "request_mode": {
                    "type": "string",
                    "enum": [
                      "simple",
                      "odrp",
                      "membership"
                    ],
                    "description": "If simple the payment request is made for a one shot payment only.\n\nIf \"membership\", the parameters inside membership is mandatory. All payment will be manage on our side and it will automatically go through as configured with the parameters.\n\nIf \"odrp\" (On Demand Recurring Payment), the client will be informed on the generated payment page that, over and above the order he is paying for, the merchant reserves the right to take any payment within the specified limits, according to his general conditions. The means of payment will be tokenized. The merchant can claim a payment either through the MiPS back office, either through the claim_odrp API. Typical usage: any merchant who wants to have a better liberty on how to leverage his clients himself. The parameters inside odrp is mandatory for this request_mode."
                  },
                  "touchpoint": {
                    "type": "string",
                    "enum": [
                      "native_app",
                      "web"
                    ]
                  },
                  "odrp": {
                    "type": "object",
                    "properties": {
                      "max_amount_total": {
                        "type": "number",
                        "description": "Optional.\n\nThis is displayed to the client according with wordings relative to the request_mode.\n\nIn odrp mode, this is the max cumulated amount claimable before the max_date.\n\nFor odrp mode, you can let this field emptyt if you don't need a maximum amount."
                      },
                      "max_amount_per_claim": {
                        "type": "number",
                        "description": "Optional.\n\nThis is displayed to the client according with wordings relative to the request_mode.\n\nIn odrp mode, this is the max amount claimable at each claim."
                      },
                      "max_frequency": {
                        "type": "integer",
                        "description": "Optional.\n\nThis is displayed to the client according with wordings relative to the request_mode.\n\nIn odrp mode, this is the max number of claims per month."
                      },
                      "max_date": {
                        "type": "string",
                        "format": "date",
                        "description": "Optional.\n\nThis is displayed to the client according with wordings relative to the request_mode.\n\nIn odrp mode, this is the max date after which no claim will be available. The Token will be deleted as from this date."
                      }
                    }
                  },
                  "membership": {
                    "type": "object",
                    "properties": {
                      "interval": {
                        "type": "number",
                        "description": "Every INTERVAL month, day etc.",
                        "multipleOf": 1,
                        "example": 1,
                        "minimum": 0
                      },
                      "start_date": {
                        "type": "string",
                        "format": "date"
                      },
                      "frequency": {
                        "type": "string",
                        "maxLength": 8,
                        "enum": [
                          "day",
                          "week",
                          "month",
                          "year"
                        ],
                        "example": "month"
                      },
                      "end_date": {
                        "type": "string",
                        "format": "date"
                      },
                      "day_to_process": {
                        "type": "number",
                        "minimum": 1,
                        "maximum": 28,
                        "example": 5,
                        "multipleOf": 1
                      },
                      "membership_amount": {
                        "type": "number",
                        "example": 1240.05
                      }
                    }
                  },
                  "additional_params": {
                    "type": "array",
                    "description": "The merchant puts here any parameter he wants to get back when a payment is sucessful. The values will be sent back through the IMN callback exactly as it was put in. Typically the merchant wants to insert here some tracking IDs.\n\nImportant, the only tracking ID MiPS will use is the id_order above",
                    "items": {
                      "type": "object",
                      "properties": {
                        "param_name": {
                          "type": "string"
                        },
                        "param_value": {
                          "type": "string"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "description": ""
        },
        "x-internal": false,
        "description": "This API call gives back a HTML code, generating the iframe. It allows the merchant to output an HTML payment zone within an iframe.\n\nImportant: The result of this API call is NOT a Token nor a payment result. The Token or the payment result will be sent to the IMN URL given by the merchant only when a tokenization or payment is successful.\n\nThe look & feel of the iFrame is automatically generated.",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "example": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/60.0.3112.78 Safari/537.36"
            },
            "in": "header",
            "name": "user-agent",
            "description": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/60.0.3112.78 Safari/537.36",
            "required": true
          },
          {
            "schema": {
              "type": "string"
            },
            "in": "header",
            "name": "Content-Type",
            "description": "application/json",
            "required": true
          }
        ],
        "security": [
          {
            "Basic auth credentials": []
          }
        ]
      },
      "parameters": []
    },
