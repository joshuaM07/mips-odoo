          },
          {
            "schema": {
              "type": "string"
            },
            "in": "header",
            "name": "Content-Type",
            "description": "application/json",
            "required": true
          }
        ],
        "security": [
          {
            "Basic auth credentials": []
          }
        ]
      },
      "parameters": []
    },
    "/IMN_CALLBACK_ARCH": {
      "post": {
        "summary": "IMN CALLBACK ARCHITECTURE",
        "responses": {
          "200": {
            "description": "This response is awaited from MiPS to check if the Instant Merchant Notification has successfully reached the merchant.\n\nThe IMN is sent by MiPS to the merchant upon successfull payments.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "string",
                  "enum": [
                    "success",
                    "fail"
                  ],
                  "example": "success"
                }
              }
            }
          }
        },
        "operationId": "IMN_CALLBACK",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "crypted_callback": {
                    "type": "string"
                  }
                },
                "required": [
                  "crypted_callback"
                ]
              },
              "examples": {
                "Example 1": {
                  "value": "crypted_callback=STRING&id_order=STRING"
                }
              }
            }
          },
          "description": "MiPS sends you a HTTP request upon a successful payment"
