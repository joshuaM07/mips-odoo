    "/orders_management": {
      "post": {
        "summary": "Order Management",
        "tags": [],
        "responses": {
          "200": {
            "description": "The response is a array containing one (1) or many orders.\n\nMany orders are only sent for get_order_list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "orders": {
                      "type": "array",
                      "description": "Only relevant data will be sent back depending on the \"instruction\" parameter sent in the query.\n\nExample: if the instruction apram = get_order_link, only the link data will be populated.\n\nTo get **all** the data of an order, use the instruction \"get_order_all_data\"\n\n",
                      "items": {
                        "$ref": "../models/Order-details.json"
                      }
                    },
                    "operation_status": {
                      "type": "string",
                      "enum": [
                        "success",
                        "fail"
                      ]
                    },
                    "operation_details": {
                      "type": "string",
                      "description": "Details if operation_status is failed"
                    }
                  },
                  "required": [
                    "operation_status"
                  ]
                }
              }
            }
          }
        },
        "operationId": "orders_management",
        "description": "the merchant interacts here with his previously generated orders",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "example": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/60.0.3112.78 Safari/537.36"
            },
            "in": "header",
            "name": "user-agent",
            "description": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/60.0.3112.78 Safari/537.36",
            "required": true
          },
          {
            "schema": {
              "type": "string"
            },
            "in": "header",
            "name": "Content-Type",
            "description": "application/json",
            "required": true
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "authentify": {
                    "$ref": "../models/Authentify.json"
                  },
                  "instruction": {
                    "type": "string",
                    "enum": [
                      "cancel_order",
                      "refund_order",
                      "get_order_list",
                      "get_order_link",
                      "get_order_all_data",
                      "get_order_qr",
                      "resend_order_by_email",
                      "resend_order_by_sms",
                      "get_next_payment_date"
                    ],
                    "example": "cancel_order"
                  },
                  "order": {
                    "$ref": "../models/Order.json"
                  },
                  "description": {
                    "type": "string",
                    "description": "Can be use to add a reason to the refund or a reason for an order cancellation"
                  },
                  "search_param": {
                    "type": "object",
                    "description": "This param is compolsury for instruction = get_order_list.\n\nPlease note that this parameter has not yet been implemented.",
                    "properties": {
                      "last_payment_status": {
                        "type": "string",
                        "enum": [
                          "success",
                          "fail",
                          "error"
                        ]
                      },
                      "client_order_number": {
                        "type": "string"
                      },
                      "from_date": {
                        "type": "string",
                        "format": "date-time",
                        "default": "yyyy-mm-dd H:i:s",
                        "example": "2022-03-12 10:48:28"
                      },
                      "to_date": {
                        "type": "string",
                        "format": "date-time",
                        "default": "yyyy-mm-dd H:i:s",
                        "example": "2022-03-12 10:48:28"
                      },
                      "order_amount": {
                        "type": "number"
                      },
                      "order_currency": {
                        "type": "string"
                      }
                    }
                  }
                },
                "required": [
                  "authentify",
                  "instruction"
                ]
              }
            }
          },
          "description": "id_order is compolsury for all instructions related to an specific order. Example, get_order_list does not require an id_order."
        },
        "security": [
          {
            "Basic auth credentials": []
          }
        ]
      }
    },
    "/decrypt_imn_data": {
      "post": {
        "summary": "Decrypt IMN Callback data",
        "responses": {
          "200": {
            "description": "This is received by the merchant after decrypting the crypted Instant Merchant notification callback.\n\nThis answer contains all needed data for the merchant to update his databases and process the operations after a successful payment (send invoices, updates orders, etc.)\n\nDepending on the type of payment needed (one off, membership, odrp, etc.) the answer contains the relevant datas.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../models/IMN-decrypted-callback.json"
                }
              }
            }
          }
        },
        "operationId": "decrypt-imn-data",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "authentify": {
                    "$ref": "../models/Authentify.json"
                  },
                  "salt": {
                    "type": "string",
                    "description": "Provided by MiPS"
                  },
                  "cipher_key": {
                    "type": "string",
                    "description": "Provided by MiPS"
                  },
                  "received_crypted_data": {
                    "type": "string",
                    "description": "The crypted data received through the IMN CALLBACK"
                  }
                },
                "required": [
                  "authentify",
                  "salt",
                  "cipher_key",
                  "received_crypted_data"
                ]
              }
            }
          },
          "description": ""
        },
        "x-internal": false,
        "description": "This API is to be called when the merchant receives an IMN Callback.",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "example": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/60.0.3112.78 Safari/537.36"
            },
            "in": "header",
            "name": "user-agent",
