{
  "openapi": "3.1.0",
  "info": {
    "title": "Merchant Endpoints",
    "version": "2.7",
    "summary": "Loads the MiPS Payment zone within your environment through an iFrame.",
    "description": "Loads the MiPS Payment zone within your environment through an iFrame."
  },
  "servers": [
    {
      "url": "https://api.mips.mu/api/",
      "description": "MiPS API server"
    }
  ],
  "paths": {
    "/create_payment_request": {
      "post": {
        "summary": "Create payment request",
        "responses": {
          "200": {
            "description": "MiPS automatically generates a link where the payment or capture zone will be hosted. MiPS sends back the URL and a QRCode embedding the payment link.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "operation_status": {
                      "type": "string",
                      "enum": [
                        "success",
                        "fail"
                      ]
                    },
                    "operation_details": {
                      "type": "string"
                    },
                    "payment_link": {
                      "$ref": "../models/Payment-link-response.json"
                    }
                  },
                  "required": [
                    "payment_link"
                  ]
                }
              }
            }
          }
        },
        "operationId": "create_payment_request",
        "description": "The merchant gets a link where a client can Tokenize his means of payments. Optionally the client can also pay something at this time.\n\nThis API is typically useful for merchants who want to take an initial payment (deposit, warranty, fees, initial order, etc.) and then, afterwards, trigger other payments without having to ask again the means of payment used to his client.\n\nImportant, the maximum frequency and amounts allowed are fixed at upfront and must be according to the General Conditions provided to MiPS.\n\nThe merchant can decide to just get the link or to have MiPS send the link through mail on his behalf.\n\nThe mail design template is made through the Merchant MiPS back office.\n\nThe link in any case is sent back under an URL format + under a QR code in base 64 Format\n\nIMPORTANT: When a payment is successful for a generated payment request. MiPS will send a callback to the merchant. Please see IMN (Instant Merchant Notification callback).",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "example": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/60.0.3112.78 Safari/537.36"
            },
            "in": "header",
            "name": "user-agent",
            "description": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/60.0.3112.78 Safari/537.36",
            "required": true
          },
          {
            "schema": {
              "type": "string"
            },
            "in": "header",
            "name": "Content-Type",
            "description": "application/json",
            "required": true
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "authentify": {
                    "$ref": "../models/Authentify.json"
                  },
                  "request": {
                    "$ref": "../models/Payment-link-generation.json"
                  },
                  "initial_payment": {
                    "$ref": "../models/Order.json"
                  },
                  "iframe_behavior": {
                    "type": [
                      "object"
                    ],
                    "x-stoplight": {
                      "id": "q074kilpwmza6"
                    },
                    "properties": {
                      "custom_redirection_url": {
                        "type": "string",
                        "x-stoplight": {
                          "id": "caqms463rwq3d"
                        },
                        "description": "Should be added with prefix 'http' or 'https'"
                      }
                    }
                  }
                },
                "required": [
                  "authentify",
                  "request"
                ]
              }
            }
          }
        },
        "security": [
          {
            "Basic auth credentials": []
          }
        ]
      },
      "parameters": []
    },
    "/claim_payment_request": {
      "post": {
        "summary": "Claim payment request",
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "payment_status": {
                      "type": "string",
                      "enum": [
                        "SUCCESS",
                        "FAIL",
                        "ERROR",
                        "Rejected"
                      ],
                      "example": "Rejected"
                    },
                    "Reason": {
                      "type": "string",
                      "enum": [
                        "APPROVED",
                        "DECLINED",
                        "INSUFFICIENT_FUNDS",
                        "BLOCKED",
                        "Claim Amount is greater that the specified Amount Claimable",
                        "You have already reached Maximum number of cliams for this month.",
                        "Maximum date for claims reached.",
                        "You have reached the Maximum Amount Claimable"
                      ],
                      "example": "APPROVED"
                    }
                  }
                }
              }
            }
          }
        },
        "operationId": "claim_payment_request",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "authentify": {
                    "$ref": "../models/Authentify.json"
                  },
                  "order": {
                    "$ref": "../models/Order.json"
                  },
                  "id_token": {
                    "type": "string",
                    "minLength": 128,
                    "maxLength": 128
                  },
                  "balance_number": {
                    "type": "number",
                    "description": "To use only for balance manual claim\nrefer to initial balances number"
                  }
                },
                "required": [
                  "authentify",
                  "id_token"
                ]
              }
            }
          },
          "description": "if \"deposit\" was selected, \"order\" must be empty and \"balance_number\" triggered"
        },
        "parameters": [
          {
            "schema": {
              "type": "string",
              "example": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/60.0.3112.78 Safari/537.36"
            },
            "in": "header",
            "name": "user-agent",
            "description": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/60.0.3112.78 Safari/537.36",
            "required": true
          },
          {
            "schema": {
              "type": "array"
            },
            "in": "header",
            "name": "Content-Type",
            "description": "application/json",
            "required": true
          }
        ],
        "description": "When a means of payment has been tokenized (memorized), The merchant can claim the payments.\n\nThe amounts and frequencies of claimed payments must remain within the specified \"max\" sent in \"load_iframe' API or \"create_payment_request\" API.",
        "security": [
          {
            "Basic auth credentials": []
          }
        ]
      }
    },
